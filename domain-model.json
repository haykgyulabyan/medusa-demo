{
  "$schema": "https://app.qlerify.com/schemas/domain-model/v1.json",
  "version": 1,
  "boundedContext": "Medusa (improved-v2)",
  "roles": [
    "Customer",
    "Automation"
  ],
  "domainEvents": {
    "CartCreated": {
      "event": "Cart Created",
      "role": "Customer",
      "follows": [
        "start"
      ],
      "command": {
        "$ref": "#/schemas/commands/CreateCart"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartCreationContext",
          "array": true
        }
      ],
      "acceptanceCriteria": [
        "Given no cart exists for this shopping session and the customer has selected a currency, when the customer invokes Create Cart on Cart, then a new cart is created with the initial state and currency code."
      ]
    },
    "CartUpdated": {
      "event": "Cart Updated",
      "role": "Customer",
      "follows": [
        {
          "$ref": "#/domainEvents/CartCreated"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/UpdateCart"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartDetails"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart is available, when the customer invokes Update Cart on Cart with changed fields such as region, email, customer, addresses, or metadata, then the cart is updated with only those changed fields."
      ]
    },
    "CartItemAdded": {
      "event": "Cart Item Added",
      "role": "Customer",
      "follows": [
        {
          "$ref": "#/domainEvents/CartUpdated"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/AddCartItem"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartDetails"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart and a product variant selected by the customer, when the customer invokes Add Cart Item on Cart with a valid item snapshot and quantity greater than zero, then the line item is added to the cart."
      ]
    },
    "CartItemUpdated": {
      "event": "Cart Item Updated",
      "role": "Customer",
      "follows": [
        {
          "$ref": "#/domainEvents/CartItemAdded"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/UpdateCartItem"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartDetails"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart that already contains a line item, when the customer invokes Update Cart Item on Cart with changed item fields such as quantity, then the matching line item in the cart is updated."
      ]
    },
    "CartItemRemoved": {
      "event": "Cart Item Removed",
      "role": "Customer",
      "follows": [
        {
          "$ref": "#/domainEvents/CartItemUpdated"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/RemoveCartItem"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartDetails"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart that contains a specific line item, when the customer invokes Remove Cart Item on Cart for that item, then the line item is removed from the cart."
      ]
    },
    "CartShippingMethodAdded": {
      "event": "Cart Shipping Method Added",
      "role": "Customer",
      "follows": [
        {
          "$ref": "#/domainEvents/CartItemRemoved"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/AddShippingMethod"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartShippingOptions"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart and an available shipping option for the cart context, when the customer invokes Add Shipping Method on Cart with shipping method data, then the shipping method is added to the cart."
      ]
    },
    "CartShippingMethodRemoved": {
      "event": "Cart Shipping Method Removed",
      "role": "Customer",
      "follows": [
        {
          "$ref": "#/domainEvents/CartShippingMethodAdded"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/RemoveShippingMethod"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartDetails"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart that contains a shipping method, when the customer invokes Remove Shipping Method on Cart for that shipping method, then the shipping method is removed from the cart."
      ]
    },
    "CartCreditLineAdded": {
      "event": "Cart Credit Line Added",
      "role": "Customer",
      "follows": [
        {
          "$ref": "#/domainEvents/CartShippingMethodRemoved"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/AddCreditLine"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartCreditOptions"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart and a valid credit source or amount, when the customer invokes Add Credit Line on Cart with credit line data, then the credit line is added to the cart."
      ]
    },
    "CartCreditLineRemoved": {
      "event": "Cart Credit Line Removed",
      "role": "Customer",
      "follows": [
        {
          "$ref": "#/domainEvents/CartCreditLineAdded"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/RemoveCreditLine"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartDetails"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart that contains a credit line, when the customer invokes Remove Credit Line on Cart for that credit line, then the credit line is removed from the cart."
      ]
    },
    "CartPricingRecalculated": {
      "event": "Cart Pricing Recalculated",
      "role": "Automation",
      "follows": [
        {
          "$ref": "#/domainEvents/CartCreditLineRemoved"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/RecalculateCartPricing"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCartDetails"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart whose items, shipping methods, and credits may have changed, when Automation invokes Recalculate Cart Pricing on Cart, then the cart pricing is recalculated and the adjustment and tax line sets are replaced with the new computed values."
      ]
    },
    "CartCompleted": {
      "event": "Cart Completed",
      "role": "Customer",
      "follows": [
        {
          "$ref": "#/domainEvents/CartPricingRecalculated"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/CompleteCart"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/Cart"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetCheckoutSummary"
        }
      ],
      "acceptanceCriteria": [
        "Given an existing cart with all required checkout information and current pricing, when the customer invokes Complete Cart on Cart, then the cart is marked as completed with a completed at timestamp."
      ]
    }
  },
